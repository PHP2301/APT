@model APT.Models.Apartment
@{
    Layout = null;
    var res = Model?.Resident;

    decimal roomPrice = Model?.RentPrice ?? 0;
    decimal managementPrice = (Model?.Area ?? 0) * 6000;
    var latestBill = ViewBag.LatestBill as APT.Models.Bill;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Hóa đơn phòng @Model.FullRoomName</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body class="bg-[#f1f3f5] flex h-screen">

    <aside class="w-64 bg-[#7d939e] p-8 text-white shrink-0">
        <div class="flex flex-col items-center border-b border-white/20 pb-8 mb-8">
            <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center text-2xl font-black mb-2">APT</div>
            <p class="text-[10px] font-bold tracking-[4px] opacity-60">MANAGEMENT</p>
        </div>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto">
        <div class="bg-[#2c3e50] text-white px-6 py-4 rounded-t-3xl flex justify-between items-center shadow-lg">
            <h2 class="font-bold uppercase text-sm tracking-widest flex items-center gap-2">
                <i class="fa-solid fa-door-closed"></i> Phòng @Model.FullRoomName
                <span class="ml-2 bg-green-500/20 text-green-400 px-3 py-1 rounded-full text-[10px]">Đang thuê</span>
            </h2>
            <a asp-controller="Apartments"
               asp-action="Index"
               asp-route-building_id="@Model.building_id"
               class="text-xs bg-white/10 hover:bg-white/20 px-4 py-2 rounded-xl no-underline text-white transition-all">
                <i class="fa-solid fa-arrow-left mr-1"></i> Quay lại
            </a>
        </div>

        <div class="grid grid-cols-3 gap-6 mt-6">
            <div class="col-span-2 space-y-6">
                @* THÔNG TIN CƯ DÂN *@
                <div class="bg-white p-8 rounded-[32px] shadow-sm border border-gray-100">
                    <h3 class="font-bold text-gray-400 text-[10px] uppercase tracking-[3px] mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-id-card"></i> Thông tin cư dân
                    </h3>
                    @if (res != null)
                    {
                        <div class="flex items-center gap-6">
                            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=@res.FullName" class="w-16 h-16 rounded-3xl border-4 border-gray-50 shadow-sm">
                            <div>
                                <p class="font-black text-gray-800 text-lg">@res.FullName <span class="bg-blue-50 text-blue-600 px-3 py-1 rounded-full text-[10px] ml-2 uppercase">Chủ hộ</span></p>
                                <p class="text-sm text-gray-400 font-bold mt-1"><i class="fa-solid fa-phone mr-2 text-blue-300"></i> @res.Phone</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-sm text-gray-400 italic">Phòng đang trống</p>
                    }
                </div>

                @* QUẢN LÝ NƯỚC *@
                <div class="bg-white p-8 rounded-[32px] shadow-sm border border-gray-100">
                    <h3 class="font-bold text-gray-400 text-[10px] uppercase tracking-[3px] mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-droplet text-blue-400"></i> Chỉ số nước T01
                    </h3>
                    <div class="flex gap-4 mb-8">
                        <input type="number" id="waterUsage" oninput="updateWaterInvoice()" placeholder="Số mới (m3)" class="flex-1 px-6 py-4 bg-gray-50 rounded-2xl border-2 border-transparent outline-none focus:border-blue-400 focus:bg-white text-sm font-black transition-all">
                        <button class="bg-blue-600 text-white px-6 rounded-2xl shadow-lg shadow-blue-100 hover:bg-black transition-all">
                            <i class="fa-solid fa-floppy-disk"></i>
                        </button>
                    </div>

                    <table class="w-full text-xs font-bold text-gray-500">
                        <tr class="border-b border-gray-50">
                            <td class="py-4 opacity-60 italic">Định mức 1 (4m3) - 9.125đ</td>
                            <td class="text-right py-4 font-black text-gray-700" id="step1_val">0 đ</td>
                        </tr>
                        <tr class="border-b border-gray-50">
                            <td class="py-4 opacity-60 italic">Định mức 2 (2m3) - 18.000đ</td>
                            <td class="text-right py-4 font-black text-gray-700" id="step2_val">0 đ</td>
                        </tr>
                        <tr class="border-b border-gray-50">
                            <td class="py-4 opacity-60 italic">Ngoài định mức - 19.786đ</td>
                            <td class="text-right py-4 font-black text-gray-700" id="step3_val">0 đ</td>
                        </tr>
                        <tr>
                            <td class="pt-6 uppercase tracking-widest text-gray-400">Tổng tiền nước</td>
                            <td class="pt-6 text-right text-blue-600 text-xl font-black" id="totalWaterText">0 đ</td>
                        </tr>
                    </table>
                </div>
            </div>

            @* CHI TIẾT PHÍ *@
            <div class="col-span-1">
                <div class="bg-white p-8 rounded-[32px] shadow-sm border border-gray-100 h-full">
                    <h3 class="font-bold text-gray-400 text-[10px] uppercase tracking-[3px] mb-8 flex items-center gap-2">
                        <i class="fa-solid fa-receipt"></i> Chi tiết giá
                    </h3>
                    <div class="space-y-6">
                        <div>
                            <label class="text-[9px] text-gray-300 uppercase font-black tracking-widest block mb-1">Diện tích</label>
                            <p class="font-black text-gray-700 text-lg">@Model.Area <span class="text-xs font-normal">m2</span></p>
                        </div>
                        <div>
                            <label class="text-[9px] text-gray-300 uppercase font-black tracking-widest block mb-1">Quản lý (6k/m2)</label>
                            <p class="font-black text-green-600 text-lg">@managementPrice.ToString("N0") <span class="text-xs font-normal">đ</span></p>
                        </div>
                        <div class="pt-6 border-t border-dashed">
                            <label class="text-[9px] text-gray-300 uppercase font-black tracking-widest block mb-1">Tiền phòng</label>
                            <p class="font-black text-blue-600 text-2xl">@roomPrice.ToString("N0") <span class="text-sm font-normal">đ</span></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* HÓA ĐƠN TỔNG HỢP *@
        <div class="mt-8 bg-white rounded-[40px] shadow-2xl border border-red-50 overflow-hidden">
            <div class="bg-red-500 px-10 py-5 flex justify-between items-center">
                <h4 class="text-xs font-black text-white uppercase tracking-[4px]"><i class="fa-solid fa-file-invoice-dollar mr-2"></i> Hóa đơn tổng hợp</h4>
                <span class="bg-white/20 text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Chưa thanh toán</span>
            </div>
            <div class="p-12">
                <div class="grid grid-cols-2 gap-x-20 gap-y-8 text-[11px] font-bold text-gray-400 uppercase tracking-widest">
                    <div class="flex justify-between border-b pb-2"><span><i class="fa-solid fa-house mr-2"></i> Phòng:</span> <span class="text-gray-800">@roomPrice.ToString("N0") đ</span></div>
                    <div class="flex justify-between border-b pb-2"><span><i class="fa-solid fa-shield mr-2"></i> Quản lý:</span> <span class="text-gray-800">@managementPrice.ToString("N0") đ</span></div>
                    <div class="flex justify-between border-b pb-2"><span><i class="fa-solid fa-droplet mr-2 text-blue-400"></i> Nước:</span> <span class="text-gray-800" id="billWaterText">0 đ</span></div>
                    <div class="flex justify-between border-b pb-2"><span><i class="fa-solid fa-bolt mr-2 text-yellow-500"></i> Điện:</span> <span class="text-gray-400 italic">Theo EVN</span></div>
                </div>

                <div class="mt-12 flex justify-between items-center bg-gray-50 p-8 rounded-[32px]">
                    <div>
                        <p class="text-[10px] font-black text-gray-300 uppercase tracking-[4px] mb-1">Tổng cộng cần thu</p>
                        <p class="text-5xl font-black text-red-500 tracking-tighter" id="grandTotalText">@((roomPrice + managementPrice).ToString("N0")) <span class="text-xl font-normal">đ</span></p>
                    </div>
                    <div class="flex gap-4">
                        @Html.AntiForgeryToken()
                        @* Tìm nút btnConfirm trong RoomDetails.cshtml và sửa lại như sau *@
                        <button type="button"
                                id="btnConfirm"
                                data-amount="@(roomPrice + managementPrice)" @* Luôn mặc định là tiền phòng + quản lý *@
                                onclick="confirmRoomPayment(@Model.Id)"
                                class="bg-[#2ecc71] text-white px-10 py-5 rounded-2xl font-black text-[11px] uppercase tracking-widest shadow-xl shadow-green-100 hover:bg-black hover:scale-105 transition-all">
                            <i class="fa-solid fa-check-circle mr-2 text-base"></i> XÁC NHẬN THU
                        </button>
                        <button onclick="window.print()" class="bg-white text-gray-400 border border-gray-200 px-8 py-5 rounded-2xl font-black text-[11px] uppercase tracking-widest hover:bg-gray-100 transition-all">
                            <i class="fa-solid fa-print mr-2"></i> In
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const roomPrice = @roomPrice;
        const managementPrice = @managementPrice;

        function updateWaterInvoice() {
            const usage = parseInt(document.getElementById('waterUsage').value) || 0;
            const rate1 = 9125;
            const rate2 = 18000;
            const rate3 = 19786;

            let step1 = 0, step2 = 0, step3 = 0;

            if (usage <= 4) {
                step1 = usage * rate1;
            } else if (usage <= 6) {
                step1 = 4 * rate1;
                step2 = (usage - 4) * rate2;
            } else {
                step1 = 4 * rate1;
                step2 = 2 * rate2;
                step3 = (usage - 6) * rate3;
            }

                const totalWater = step1 + step2 + step3;
        const grandTotal = roomPrice + managementPrice + totalWater;

        // HIỂN THỊ LÊN MÀN HÌNH
        document.getElementById('totalWaterText').innerText = totalWater.toLocaleString('vi-VN') + " đ";
        document.getElementById('billWaterText').innerText = totalWater.toLocaleString('vi-VN') + " đ";
        document.getElementById('grandTotalText').innerHTML = grandTotal.toLocaleString('vi-VN') + ' <span class="text-xl font-normal">đ</span>';

        // QUAN TRỌNG NHẤT: Cập nhật số tiền thực tế vào thuộc tính data-amount của nút bấm
        document.getElementById('btnConfirm').setAttribute('data-amount', grandTotal);
        }

        function confirmRoomPayment(roomId) {
            const btn = document.getElementById('btnConfirm');
            const totalAmount = parseFloat(btn.getAttribute('data-amount')) || 0;

            if (totalAmount <= 0) {
                Swal.fire('Thông báo', 'Hóa đơn này không có số tiền cần thu!', 'info');
                return;
            }

            Swal.fire({
                title: 'Xác nhận thu tiền?',
                text: `Đại Ca xác nhận đã thu ${totalAmount.toLocaleString('vi-VN')}đ từ cư dân này?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2ecc71',
                cancelButtonColor: '#95a5a6',
                confirmButtonText: 'Đã thu xong!',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                       fetch(`/Billing/AdminConfirmPayment?apartmentId=${roomId}&amount=${totalAmount}`, {
            method: 'POST',
            headers: { 'RequestVerificationToken': token }
        })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire('Thành công!', data.message, 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Thất bại', data.message, 'error');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ!', 'error');
                    });
                }
            });
        }
    </script>
</body>
</html>