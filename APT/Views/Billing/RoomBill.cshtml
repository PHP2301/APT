@model APT.Models.Apartment
@{
    Layout = null;
    var res = Model?.Resident;

    // FIX 1: Dùng toán tử ?? 0 để ép kiểu decimal? về decimal
    decimal roomPrice = Model?.RentPrice ?? 0;
    decimal managementPrice = (Model?.Area ?? 0) * 6000;

    // FIX 2: Xử lý null cho danh sách xe
    decimal vehiclePrice = res?.Vehicles?.Count * 100000 ?? 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Chi tiết Hóa đơn - Phòng @Model?.FullRoomName</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .sidebar-bg {
            background-color: #7d939e;
        }

        .animate-fade-in {
            animation: fadeIn 0.3s ease-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: scale(0.95);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }
    </style>
</head>
<body class="bg-[#f1f3f5] flex h-screen font-sans">

    @Html.AntiForgeryToken()

    <aside class="w-64 sidebar-bg flex flex-col items-center py-8 px-4 text-white shrink-0 shadow-2xl">
        <div class="w-20 h-20 rounded-full border-4 border-white overflow-hidden mb-4 bg-white">
            <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=Lucky" alt="Avatar">
        </div>
        <p class="font-bold text-sm mb-8 uppercase tracking-widest text-center">Manager</p>
        <div class="w-full space-y-2">
            <a asp-controller="Dashboard" asp-action="Index" class="flex items-center gap-3 w-full py-2.5 px-6 bg-white text-gray-500 rounded-full font-bold no-underline text-sm shadow-sm">
                <i class="fa-solid fa-house"></i> Trang chủ
            </a>
            <p class="text-[10px] uppercase font-black tracking-widest mt-6 mb-2 opacity-60 px-4 italic">Quản lý tòa nhà</p>
            <a asp-controller="Apartments" asp-action="Index" asp-route-building_id="@(Model?.building_id ?? 0)" class="flex items-center gap-3 w-full py-2.5 px-6 bg-[#d35400] text-white rounded-full font-bold no-underline text-sm shadow-lg">
                <i class="fa-solid fa-door-open"></i> Danh sách Phòng
            </a>
        </div>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto">
        <div class="bg-[#2c3e50] text-white px-8 py-4 rounded-t-[25px] flex justify-between items-center shadow-lg">
            <h2 class="font-black uppercase text-sm tracking-widest">
                Phòng @Model?.FullRoomName
                <span class="ml-3 bg-green-500/20 text-green-400 px-3 py-1 rounded-full text-[10px] border border-green-500/30">Đang thuê</span>
            </h2>
            <a href="javascript:history.back()" class="text-xs font-bold opacity-60 hover:opacity-100 transition-all no-underline text-white">← Quay lại</a>
        </div>

        <div class="grid grid-cols-3 gap-8 mt-8">
            <div class="col-span-2 space-y-8">
                <div class="bg-white p-8 rounded-[35px] shadow-sm border border-gray-100">
                    <h3 class="font-black text-gray-400 text-[10px] uppercase tracking-[3px] mb-6 flex items-center gap-2">
                        <i class="fa-solid fa-users text-blue-400 text-base"></i> Thông tin cư dân
                    </h3>
                    @if (res != null)
                    {
                        <div class="flex items-center gap-6">
                            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=@res.FullName" class="w-16 h-16 rounded-2xl border shadow-sm">
                            <div>
                                <p class="font-black text-xl text-gray-800 tracking-tighter">@res.FullName</p>
                                <p class="text-sm text-gray-400 font-bold mt-1"><i class="fa-solid fa-phone mr-1"></i> @res.phone</p>
                            </div>
                        </div>
                    }
                </div>

                <div class="bg-white p-8 rounded-[35px] shadow-sm border border-gray-100">
                    <h3 class="font-black text-gray-400 text-[10px] uppercase tracking-[3px] mb-8 flex items-center gap-2">
                        <i class="fa-solid fa-droplet text-blue-500 text-base"></i> Chỉ số Nước tháng này
                    </h3>
                    <div class="flex gap-4 mb-8">
                        <input type="number" id="waterUsage" oninput="updateWaterInvoice()" placeholder="Nhập số m3 tiêu thụ..."
                               class="flex-1 px-6 py-4 bg-gray-50 rounded-2xl border-none outline-none focus:ring-4 focus:ring-blue-100 text-sm font-black text-gray-700 transition-all">
                    </div>

                    <table class="w-full text-[11px] font-bold text-gray-500">
                        <tr class="border-b border-dashed border-gray-100"><td class="py-3">Định mức 1 (4m3) - 9.125đ</td><td class="text-right py-3 text-gray-700" id="step1_val">0 đ</td></tr>
                        <tr class="border-b border-dashed border-gray-100"><td class="py-3">Định mức 2 (2m3) - 18.000đ</td><td class="text-right py-3 text-gray-700" id="step2_val">0 đ</td></tr>
                        <tr class="border-b border-dashed border-gray-100"><td class="py-3">Ngoài định mức - 19.786đ</td><td class="text-right py-3 text-gray-700" id="step3_val">0 đ</td></tr>
                        <tr><td class="pt-6 uppercase font-black tracking-widest text-gray-400">Tổng tiền nước</td><td class="pt-6 text-right text-gray-800 text-xl font-black" id="totalWaterText">0 đ</td></tr>
                    </table>
                </div>
            </div>

            <div class="col-span-1 space-y-8">
                <div class="bg-white p-8 rounded-[35px] shadow-sm border border-gray-100">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="font-black text-gray-400 text-[10px] uppercase tracking-[3px]">Phương tiện</h3>
                        <span class="bg-purple-100 text-purple-600 px-3 py-1 rounded-lg text-[10px] font-black">@(res?.Vehicles?.Count ?? 0) XE</span>
                    </div>
                    @if (res?.Vehicles != null)
                    {
                        @foreach (var v in res.Vehicles)
                        {
                            <div class="flex justify-between items-center py-3 border-b border-dashed border-gray-100">
                                <div class="text-xs font-black text-gray-700">@v.LicensePlate <span class="block text-[9px] text-gray-400 uppercase font-bold">@v.VehicleType</span></div>
                                <span class="text-xs font-bold text-gray-800">100,000 đ</span>
                            </div>
                        }
                    }
                </div>

                <div class="bg-white p-8 rounded-[35px] shadow-sm border border-gray-100">
                    <h3 class="font-black text-gray-400 text-[10px] uppercase tracking-[3px] mb-6">Phí Quản lý</h3>
                    <div class="flex justify-between mb-4">
                        <div class="text-[10px] text-gray-400 font-black uppercase">@(Model?.Area ?? 0) m2 x 6.000đ</div>
                        @* FIX 3: Dùng .ToString("N0") trên kiểu decimal đã ép *@
                        <div class="text-sm font-black text-green-600">@managementPrice.ToString("N0") đ</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-10 bg-white rounded-[45px] shadow-2xl border border-red-50 overflow-hidden">
            <div class="bg-red-500 px-10 py-5 flex justify-between items-center text-white">
                <h4 class="text-xs font-black uppercase tracking-widest"><i class="fa-solid fa-file-invoice-dollar mr-2"></i> Hóa đơn tháng 04/2026</h4>
                <span class="bg-white/20 px-4 py-1 rounded-full text-[10px] font-black uppercase">Chưa thanh toán</span>
            </div>
            <div class="p-10">
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 text-[11px] font-bold text-gray-400 uppercase tracking-wide">
                    <div class="flex items-center gap-3"><i class="fa-solid fa-house text-gray-300"></i> Tiền phòng: <span class="text-gray-800">@roomPrice.ToString("N0") đ</span></div>
                    <div class="flex items-center gap-3"><i class="fa-solid fa-droplet text-blue-300"></i> Tiền Nước: <span class="text-gray-800" id="billWaterText">0 đ</span></div>
                    <div class="flex items-center gap-3"><i class="fa-solid fa-hand-holding-dollar text-green-300"></i> Phí Quản lý: <span class="text-gray-800">@managementPrice.ToString("N0") đ</span></div>
                    <div class="flex items-center gap-3"><i class="fa-solid fa-car text-purple-300"></i> Phí gửi xe: <span class="text-gray-800">@vehiclePrice.ToString("N0") đ</span></div>
                </div>

                <div class="mt-12 flex justify-between items-center border-t border-dashed pt-10">
                    <div>
                        <p class="text-[10px] font-black text-gray-300 uppercase tracking-[4px] mb-2">Tổng cộng phải thu</p>
                        <p class="text-5xl font-black text-red-500 tracking-tighter" id="grandTotalText">@((roomPrice + managementPrice + vehiclePrice).ToString("N0")) <span class="text-xl">đ</span></p>
                    </div>
                    <div class="flex gap-4">
                        <button onclick="openConfirmModal()" class="bg-[#27ae60] text-white px-10 py-4 rounded-2xl font-black text-xs uppercase tracking-widest shadow-xl shadow-green-100 hover:bg-black transition-all active:scale-95">
                            <i class="fa-solid fa-circle-check mr-2"></i> Xác nhận Thu
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div id="confirmModal" class="hidden fixed inset-0 bg-black/60 z-[110] flex items-center justify-center p-4 backdrop-blur-sm">
        <div class="bg-white rounded-[40px] w-full max-w-sm p-10 shadow-2xl text-center animate-fade-in">
            <div class="w-20 h-20 bg-green-50 text-green-500 rounded-full flex items-center justify-center mx-auto mb-8 border border-green-100">
                <i class="fa-solid fa-check text-4xl"></i>
            </div>
            <h3 class="text-xl font-black text-gray-800 mb-3 tracking-tighter">Xác nhận đã thu tiền?</h3>
            <p class="text-sm text-gray-400 font-bold mb-10">Số tiền: <span class="text-red-500 font-black" id="confirmAmount">0 đ</span></p>
            <div class="flex gap-4">
                <button onclick="closeConfirmModal()" class="flex-1 py-4 bg-gray-100 text-gray-500 rounded-2xl font-black text-[10px] uppercase tracking-widest">Hủy</button>
                <button onclick="submitPayment()" class="flex-1 py-4 bg-[#27ae60] text-white rounded-2xl font-black text-[10px] uppercase tracking-widest shadow-lg shadow-green-100 hover:bg-black transition-all">Đồng ý</button>
            </div>
        </div>
    </div>

    <script>
        const roomPrice = @roomPrice;
        const managementPrice = @managementPrice;
        const vehiclePrice = @vehiclePrice;

        function updateWaterInvoice() {
            const usage = parseInt(document.getElementById('waterUsage').value) || 0;
            const rate1 = 9125, rate2 = 18000, rate3 = 19786;
            let step1 = 0, step2 = 0, step3 = 0;

            if (usage <= 4) step1 = usage * rate1;
            else if (usage <= 6) { step1 = 4 * rate1; step2 = (usage - 4) * rate2; }
            else { step1 = 4 * rate1; step2 = 2 * rate2; step3 = (usage - 6) * rate3; }

            const totalWater = step1 + step2 + step3;
            document.getElementById('step1_val').innerText = step1.toLocaleString('vi-VN') + " đ";
            document.getElementById('step2_val').innerText = step2.toLocaleString('vi-VN') + " đ";
            document.getElementById('step3_val').innerText = step3.toLocaleString('vi-VN') + " đ";
            document.getElementById('totalWaterText').innerText = totalWater.toLocaleString('vi-VN') + " đ";
            document.getElementById('billWaterText').innerText = totalWater.toLocaleString('vi-VN') + " đ";

            const grandTotal = roomPrice + managementPrice + vehiclePrice + totalWater;
            document.getElementById('grandTotalText').innerHTML = grandTotal.toLocaleString('vi-VN') + ' <span class="text-xl">đ</span>';
        }

        function openConfirmModal() {
            document.getElementById('confirmAmount').innerText = document.getElementById('grandTotalText').innerText;
            document.getElementById('confirmModal').classList.remove('hidden');
        }
        function closeConfirmModal() { document.getElementById('confirmModal').classList.add('hidden'); }

        function submitPayment() {
            const aptId = "@(Model?.Id ?? 0)";
            const rawAmount = document.getElementById('grandTotalText').innerText.replace(/[^0-9]/g, '');
            // Fetch logic... (giữ nguyên của Đại Ca)
        }
    </script>
</body>
</html>