@model APT.Models.Apartment
@{
    Layout = null;
    var bId = Model?.building_id ?? 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Chỉnh sửa Căn hộ - @Model?.FullRoomName</title>

    @* 1. NẠP JQUERY ĐẦU TIÊN *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

    @* 2. CÁC THƯ VIỆN KHÁC *@
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <style>
        .sidebar-bg {
            background-color: #7d939e;
        }

        input:focus, select:focus {
            border-color: #28a745 !important;
        }

        .form-input:focus {
            box-shadow: 0 0 0 4px rgba(40, 167, 69, 0.1);
        }

        input::-webkit-outer-spin-button, input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
    </style>
</head>
<body class="flex h-screen bg-[#f8f9fa] font-sans">
    <div class="admin-logout-top">
        <a asp-controller="Users" asp-action="Logout" class="btn-logout-custom">
            <i class="fa-solid fa-power-off"></i>
            <span>Đăng xuất</span>
        </a>
    </div>

    @* --- SIDEBAR --- *@
    <aside class="w-64 sidebar-bg flex flex-col items-center py-8 px-4 text-white shrink-0 shadow-2xl">
        <div class="w-20 h-20 rounded-full border-4 border-white overflow-hidden mb-4 bg-white flex items-center justify-center">
            <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=@Model?.FullRoomName" alt="Avatar">
        </div>
        <p class="font-black text-xs mb-8 uppercase tracking-[3px] text-center opacity-80">Quản lý viên</p>

        <div class="w-full space-y-2">
            <a asp-controller="Dashboard" asp-action="Index" class="flex items-center gap-3 w-full py-2.5 px-6 bg-white/10 text-white rounded-xl font-bold no-underline text-sm hover:bg-white/20 transition-all">
                <i class="fa-solid fa-house-chimney"></i> Trang chủ
            </a>
            <p class="text-[10px] uppercase font-black tracking-widest mt-6 mb-2 opacity-40 px-4">Tòa nhà & Căn hộ</p>
            <a asp-controller="Apartments" asp-action="Index" asp-route-building_id="@bId" class="flex items-center gap-3 w-full py-2.5 px-6 bg-[#d35400] text-white rounded-xl font-bold no-underline text-sm shadow-lg hover:translate-x-1 transition-all">
                <i class="fa-solid fa-door-open"></i> Danh sách Phòng
            </a>
        </div>
    </aside>

    <main class="flex-1 flex flex-col items-center justify-center p-10 overflow-y-auto">
        <div class="bg-white rounded-[40px] shadow-2xl w-full max-w-2xl border-t-[10px] border-[#28a745] p-12 relative">

            @* --- TIÊU ĐỀ --- *@
            <div class="text-center mb-10">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-green-50 text-[#28a745] rounded-3xl mb-4 shadow-inner">
                    <i class="fa-solid fa-pen-to-square text-2xl"></i>
                </div>
                <h2 class="text-3xl font-black text-gray-800 tracking-tight">Chỉnh sửa Căn hộ</h2>
                <p class="text-sm text-gray-400 font-bold mt-2 uppercase tracking-widest">
                    Mã phòng: <span class="text-[#28a745]">@Model?.FullRoomName</span>
                </p>
            </div>

            <form asp-controller="Apartments" asp-action="Edit" method="post" class="space-y-6">
                @Html.AntiForgeryToken()

                @* --- CÁC TRƯỜNG ẨN QUAN TRỌNG --- *@
                @* Cần giữ Id để tìm bản ghi, building_id để quay lại trang cũ *@
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="building_id" />
                @* Giữ các trường ResidentId và FullRoomName ẩn để không bị mất dữ liệu khi POST *@
                <input type="hidden" asp-for="ResidentId" />
                <input type="hidden" asp-for="FullRoomName" />

                <div class="grid grid-cols-2 gap-8">
                    @* 1. Loại phòng *@
                    <div class="space-y-2">
                        <label class="text-[11px] font-black text-gray-400 uppercase ml-1 tracking-wider">Loại phòng</label>
                        <select asp-for="RoomType" class="w-full px-5 py-4 rounded-2xl border-2 border-gray-100 bg-gray-50 text-sm font-bold text-gray-700 outline-none transition-all focus:bg-white focus:border-[#28a745]">
                            <option value="Studio">Studio</option>
                            <option value="1 Bedroom">1 Bedroom</option>
                            <option value="2 Bedrooms">2 Bedrooms</option>
                            <option value="Penthouse">Penthouse</option>
                        </select>
                        <span asp-validation-for="RoomType" class="text-[10px] text-red-500 font-bold ml-2"></span>
                    </div>

                    @* 2. Diện tích *@
                    <div class="space-y-2">
                        <label class="text-[11px] font-black text-gray-400 uppercase ml-1 tracking-wider">Diện tích</label>
                        <div class="relative">
                            <input asp-for="Area" type="number" step="0.1" class="w-full px-5 py-4 rounded-2xl border-2 border-gray-100 bg-gray-50 text-sm font-bold text-gray-700 outline-none transition-all focus:bg-white focus:border-[#28a745]" />
                            <span class="absolute right-5 top-4 text-gray-300 text-[10px] font-black uppercase">m²</span>
                        </div>
                        <span asp-validation-for="Area" class="text-[10px] text-red-500 font-bold ml-2"></span>
                    </div>

                    @* 3. Giá thuê *@
                    <div class="space-y-2">
                        <label class="text-[11px] font-black text-gray-400 uppercase ml-1 tracking-wider">Giá thuê (VNĐ)</label>
                        <div class="relative">
                            <input asp-for="RentPrice" type="number" class="w-full px-5 py-4 rounded-2xl border-2 border-gray-100 bg-gray-50 text-sm font-black text-[#28a745] outline-none transition-all focus:bg-white focus:border-[#28a745]" />
                            <i class="fa-solid fa-dong-sign absolute right-5 top-5 text-green-200"></i>
                        </div>
                        <span asp-validation-for="RentPrice" class="text-[10px] text-red-500 font-bold ml-2"></span>
                    </div>

                    @* 4. Trạng thái *@
                    <div class="space-y-2">
                        <label class="text-[11px] font-black text-gray-400 uppercase ml-1 tracking-wider">Trạng thái</label>
                        <select asp-for="Status" class="w-full px-5 py-4 rounded-2xl border-2 border-gray-100 bg-gray-50 text-sm font-bold text-gray-700 outline-none transition-all focus:bg-white focus:border-[#28a745]">
                            <option value="Available">🟢 Trống (Available)</option>
                            <option value="Maintenance">🟡 Bảo trì (Maintenance)</option>
                            <option value="Occupied">🔴 Đang ở (Occupied)</option>
                        </select>
                        <span asp-validation-for="Status" class="text-[10px] text-red-500 font-bold ml-2"></span>
                    </div>
                </div>

                @* --- NÚT ĐIỀU HƯỚNG --- *@
                <div class="flex flex-col sm:flex-row justify-center gap-4 pt-10">
                    <a asp-controller="Apartments" asp-action="Index" asp-route-building_id="@bId"
                       class="order-2 sm:order-1 px-12 py-4 bg-gray-100 text-gray-500 rounded-2xl font-black text-[11px] uppercase tracking-widest hover:bg-gray-200 transition-all text-center no-underline">
                        Hủy bỏ
                    </a>

                    <button type="submit" class="order-1 sm:order-2 px-12 py-4 bg-[#28a745] text-white rounded-2xl font-black text-[11px] uppercase tracking-widest shadow-[0_15px_30px_rgba(40,167,69,0.2)] hover:shadow-none hover:translate-y-1 active:scale-95 transition-all flex items-center justify-center gap-2">
                        <i class="fa-solid fa-cloud-arrow-up"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </main>

    @* --- SCRIPT VALIDATION --- *@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

</body>
</html>