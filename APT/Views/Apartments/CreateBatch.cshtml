@{
    Layout = "_Layout";
    ViewData["Title"] = "Tạo phòng hàng loạt";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-[#f5ebe0] py-8 px-4 md:px-10">
    <a asp-controller="Dashboard" asp-action="ChooseBuilding" class="text-[#7f5539] font-bold no-underline hover:underline mb-6 inline-block flex items-center gap-2">
        <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
    </a>

    <div class="max-w-6xl mx-auto bg-[#ddb892] rounded-[40px] p-8 md:p-12 shadow-2xl">
        <h2 class="text-[#8b0000] text-3xl font-black text-center mb-10 uppercase tracking-tighter">
            <i class="fa-solid fa-wand-magic-sparkles mr-2"></i> Tạo phòng tự động
        </h2>

        <form asp-action="ProcessCreateBatch" method="post">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

                <div class="bg-white rounded-[30px] p-8 shadow-xl border-t-8 border-[#d35400]">
                    <h3 class="text-[#4a3728] font-bold text-xl mb-6 border-b pb-2">1. Cấu hình cơ bản</h3>

                    <div class="space-y-5">
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1">Chọn Tòa nhà *</label>
                            <select name="BuildingId" class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:ring-2 focus:ring-[#d35400]" required>
                                <option value="">-- Chọn tòa nhà --</option>
                                @foreach (var b in (IEnumerable<APT.Models.Building>)ViewBag.Buildings)
                                {
                                    <option value="@b.Id">@b.Name</option>
                                }
                            </select>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-1">Từ tầng *</label>
                                <input type="number" id="fromFloor" name="FromFloor" value="1" class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:ring-2 focus:ring-[#d35400]" required />
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-1">Đến tầng *</label>
                                <input type="number" id="toFloor" name="ToFloor" value="5" class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:ring-2 focus:ring-[#d35400]" required />
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-1">Số phòng mỗi tầng (VD: 8) *</label>
                            <input type="number" name="RoomsPerFloor" value="8" class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:ring-2 focus:ring-[#d35400]" required />
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-1">Loại phòng</label>
                                <select name="Type" class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:ring-2 focus:ring-[#d35400]">
                                    <option>Studio</option>
                                    <option>1 Phòng ngủ</option>
                                    <option>2 Phòng ngủ</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-gray-700 mb-1">Diện tích (m2)</label>
                                <input type="number" name="Area" value="30" class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:ring-2 focus:ring-[#d35400]" />
                            </div>
                        </div>

                        <div class="bg-orange-50 p-6 rounded-2xl border border-orange-200 mt-6">
                            <label class="block text-sm font-bold text-[#d35400] mb-2">💰 Giá thuê cơ bản (VNĐ)</label>
                            <input type="number" id="basePrice" placeholder="Nhập giá chung để áp dụng..." class="w-full px-4 py-3 rounded-xl border-none shadow-inner mb-3 outline-none focus:ring-2 focus:ring-[#d35400]" />
                            <button type="button" onclick="applyBasePrice()" class="w-full bg-[#27ae60] text-white py-3 rounded-xl font-bold hover:bg-[#1e8449] transition-all flex items-center justify-center gap-2">
                                <i class="fa-solid fa-check-double"></i> Áp dụng cho tất cả các tầng
                            </button>
                            <p class="text-[10px] text-gray-500 mt-2 italic text-center text-orange-700">Nhập giá vào đây rồi bấm nút để điền nhanh cho bảng bên phải.</p>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-[30px] p-8 shadow-xl border-t-8 border-[#d35400] flex flex-col">
                    <h3 class="text-[#4a3728] font-bold text-xl mb-4 border-b pb-2">2. Chi tiết giá theo tầng</h3>
                    <p class="text-xs text-gray-500 mb-6">Bạn có thể chỉnh sửa giá riêng cho từng tầng tại đây (Tầng cao giá cao).</p>

                    <div class="flex-grow overflow-y-auto max-h-[400px] mb-6 custom-scrollbar">
                        <table class="w-full text-left">
                            <thead class="bg-[#d35400] text-white sticky top-0">
                                <tr>
                                    <th class="px-4 py-3 rounded-tl-xl">Tầng</th>
                                    <th class="px-4 py-3 rounded-tr-xl">Giá thuê (VNĐ)</th>
                                </tr>
                            </thead>
                            <tbody id="floorPriceBody" class="divide-y divide-gray-100">
                            </tbody>
                        </table>
                    </div>

                    <button type="submit" class="w-full bg-[#d35400] text-white py-5 rounded-2xl font-black text-xl hover:bg-[#a04000] shadow-xl hover:shadow-orange-200 transition-all flex items-center justify-center gap-3">
                        <i class="fa-solid fa-rocket"></i> Tạo Phòng Ngay
                    </button>
                </div>

            </div>
        </form>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #ddb892;
        border-radius: 10px;
    }
</style>

@section Scripts {
    <script>
        const fromFloorInput = document.getElementById('fromFloor');
        const toFloorInput = document.getElementById('toFloor');
        const floorBody = document.getElementById('floorPriceBody');

        function renderFloors() {
            const from = parseInt(fromFloorInput.value);
            const to = parseInt(toFloorInput.value);
            floorBody.innerHTML = '';

            if (isNaN(from) || isNaN(to) || from > to) return;

            for (let i = from; i <= to; i++) {

        floorBody.innerHTML += `
            <tr class="hover:bg-gray-50">
                <td class="px-4 py-4 font-bold text-gray-700">Tầng ${i}</td>
                <td class="px-4 py-4">
                    <input type="number" name="FloorPrices[${i}]" class="floor-price-input w-full px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-orange-500" placeholder="Nhập giá tầng ${i}..." required />
                </td>
            </tr>
        `;
            }
        }

        function applyBasePrice() {
            const basePrice = document.getElementById('basePrice').value;
            const inputs = document.querySelectorAll('.floor-price-input');
            inputs.forEach(input => {
                input.value = basePrice;
            });
        }

        // Tự động vẽ lại bảng khi thay đổi số tầng
        fromFloorInput.addEventListener('change', renderFloors);
        toFloorInput.addEventListener('change', renderFloors);

        // Khởi tạo lần đầu
        renderFloors();
    </script>
}