<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - APT Apartment</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .admin-logout-top {
            position: fixed;
            top: 20px;
            right: 30px;
            z-index: 9999;
        }

        .btn-logout-custom {
            background-color: #ffffff;
            color: #7d939e;
            padding: 8px 20px;
            border-radius: 12px;
            font-weight: 800;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none !important;
        }

            .btn-logout-custom:hover {
                background-color: #ef4444;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(239, 68, 68, 0.3);
            }
        /* Màu cam chủ đạo giống hình Đại Ca gửi */
        .navbar-custom {
            background-color: #d35400 !important;
        }

        .nav-link-custom {
            color: white !important;
            font-weight: bold;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 0.5rem 1rem !important;
            transition: all 0.3s;
        }

            .nav-link-custom:hover {
                background-color: rgba(255,255,255,0.1);
                border-radius: 8px;
            }

        .navbar-brand-custom {
            color: white !important;
            font-weight: 900;
            letter-spacing: -1px;
        }
    </style>
</head>
<body class="bg-[#f5ebe0]">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark navbar-custom border-bottom box-shadow mb-3 py-3">
            <div class="container-fluid px-4 flex justify-between items-center">
                @* --- GÓC TRÁI: LOGO --- *@
                <a class="navbar-brand navbar-brand-custom flex items-center gap-2" asp-controller="Admin" asp-action="Dashboard">
                    <i class="fa-solid fa-building-user text-2xl"></i>
                    <span class="tracking-tighter">APARTMENT</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                @* --- GIỮA: MENU ĐIỀU HƯỚNG --- *@
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-center">
                    <ul class="navbar-nav gap-2 items-center">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Admin" asp-action="Dashboard">
                                <i class="fa-solid fa-gauge-high mr-1"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Buildings" asp-action="ChooseBuilding">
                                <i class="fa-solid fa-city mr-1"></i> Tòa nhà
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Dashboard" asp-action="ManagerList">
                                <i class="fa-solid fa-user-tie mr-1"></i> Nhân sự
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-controller="Buildings" asp-action="ChooseBuilding">
                                <i class="fa-solid fa-door-open mr-1"></i> Căn hộ
                            </a>
                        </li>
                    </ul>
                </div>

                @* --- GÓC PHẢI TUYỆT ĐỐI: NÚT ĐĂNG XUẤT XỊN --- *@
                <div class="flex items-center gap-4 border-l border-white/20 pl-6">
                    <div class="text-right hidden md:block">
                        <p class="text-white text-[10px] font-black uppercase tracking-widest leading-none">Đại Ca</p>
                        <p class="text-white/60 text-[9px] font-bold italic">Online</p>
                    </div>
                    <a asp-controller="Users" asp-action="Logout"
                       class="bg-white/10 hover:bg-red-500 text-white w-10 h-10 flex items-center justify-center rounded-xl transition-all shadow-lg border border-white/10 group">
                        <i class="fa-solid fa-power-off group-hover:scale-110 transition-transform"></i>
                    </a>
                </div>

            </div>
        </nav>
    </header>

    <div class="container-fluid px-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted mt-10 pb-4">
        <div class="container text-center text-[10px] font-bold uppercase tracking-widest">
            &copy; 2026 - APT SYSTEM MANAGEMENT - <a asp-controller="Home" asp-action="Privacy" class="text-orange-600 no-underline">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>