@model IEnumerable<APT.Models.User>
@{
    Layout = "_Layout";
}
<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-[#f5ebe0] py-8 px-4">
    <a asp-controller="Admin" asp-action="Dashboard" class="text-[#7f5539] font-medium no-underline hover:underline mb-4 inline-block">
        ← Quay lại danh sách
    </a>

    <div class="max-w-7xl mx-auto bg-[#ddb892] rounded-[40px] p-8 shadow-2xl">
        <div class="text-center mb-8">
            <h2 class="text-[#8b0000] text-2xl font-bold flex items-center justify-center gap-2">
                <i class="fa-solid fa-users-gear"></i> Quản lý Nhân sự: IDICO
            </h2>
            <p class="text-[#4a3728] text-sm font-bold mt-2">
                Quản lý tòa nhà: điện biên phủ, Thị trấn Tây Đằng, Huyện Ba Vì, Thành phố Hà Nội
            </p>
        </div>

        <div class="grid grid-cols-12 gap-8">
            <div class="col-span-12 lg:col-span-4 bg-white rounded-3xl p-6 shadow-lg h-fit">
                <h3 class="text-[#4a3728] font-bold mb-6 flex items-center gap-2">
                    <i class="fa-solid fa-user-plus"></i> Thêm Manager
                </h3>

                <form asp-action="AddManager" method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Họ và Tên *</label>
                        <input type="text" name="FullName" placeholder="Nhập họ tên đầy đủ..." class="w-full px-4 py-2 border rounded-xl outline-none focus:ring-2 focus:ring-orange-500" required />
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Số điện thoại (Login ID) *</label>
                        <input type="text" name="Phone" placeholder="Nhập đúng 10 số..." class="w-full px-4 py-2 border rounded-xl outline-none focus:ring-2 focus:ring-orange-500" required />
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-1">Email *</label>
                        <input type="email" name="Email" placeholder="VD: user@domain.com" class="w-full px-4 py-2 border rounded-xl outline-none focus:ring-2 focus:ring-orange-500" required />
                    </div>

                    <div class="bg-orange-50 p-3 rounded-xl border border-orange-200">
                        <p class="text-xs text-[#d35400]">
                            ℹ <strong>Lưu ý:</strong> Tài khoản mới sẽ có một mật khẩu mặc định là <span class="font-bold">Quanly@@123</span>.
                        </p>
                    </div>

                    <button type="submit" class="w-full bg-[#d35400] text-white py-3 rounded-xl font-bold hover:bg-[#a04000] transition-all flex items-center justify-center gap-2">
                        <i class="fa-solid fa-save"></i> Lưu & Phân công
                    </button>
                </form>

                <div class="mt-4 text-center text-green-700 font-bold text-sm cursor-pointer hover:underline">
                    <i class="fa-solid fa-file-excel"></i> Import Excel (CSV)
                </div>
            </div>

            <div class="col-span-12 lg:col-span-8">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-[#4a3728] font-bold">Danh sách Manager</h3>
                    <div class="relative w-64">
                        <input type="text" placeholder="Tìm kiếm nhanh..." class="w-full pl-10 pr-4 py-2 rounded-full border-none outline-none shadow-sm text-sm" />
                        <i class="fa-solid fa-search absolute left-4 top-3 text-gray-400"></i>
                    </div>
                </div>

                <div class="bg-white rounded-3xl shadow-lg overflow-hidden">
                    <table class="w-full text-sm text-left">
                        <thead class="bg-[#d35400] text-white uppercase text-xs">
                            <tr>
                                <th class="px-4 py-4 text-center">Tên Manager</th>
                                <th class="px-4 py-4 text-center">SĐT</th>
                                <th class="px-4 py-4 text-center">Email</th>
                                <th class="px-4 py-4 text-center">Tòa quản lý</th>
                                <th class="px-4 py-4 text-center">Hiện</th>
                                <th class="px-4 py-4 text-center">Tác vụ</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var item in Model)
                            {
                                <tr class="hover:bg-orange-50 transition-colors">
                                    <td class="px-4 py-4 font-bold text-[#d35400]">@item.FullName</td>
                                    <td class="px-4 py-4 text-center">@item.Phone</td>
                                    <td class="px-4 py-4 text-center">@item.Email</td>
                                    <td class="px-4 py-4 text-center">
                                        <span class="bg-gray-100 px-2 py-1 rounded-md text-xs">IDICO</span>
                                    </td>
                                    <td class="px-4 py-4 text-center">
                                        <span class="bg-[#0d9488] text-white px-2 py-1 rounded-full text-[10px]">1</span>
                                    </td>
                                    <td class="px-4 py-4 text-center text-green-600 text-lg">
                                        <button class="hover:scale-110 transition-transform"><i class="fa-solid fa-user-check"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="flex justify-end gap-2 mt-6">
                    <button class="px-3 py-1 text-gray-600">Trước</button>
                    <button class="px-3 py-1 bg-orange-200 rounded-lg font-bold">1</button>
                    <button class="px-3 py-1">2</button>
                    <button class="px-3 py-1">3</button>
                    <button class="px-3 py-1 text-gray-600">Sau</button>
                </div>
            </div>
        </div>
    </div>
</div>