
@{
    var data = ViewBag.Data;
}

<div class="container py-4">
    <div class="dashboard-wrapper">
        <div class="text-center mb-5">
            <h2 class="login-title"><i class="fa-solid fa-gauge-high me-2"></i>Bảng Điều Khiển Admin</h2>
            <p class="text-dark">Chào mừng <strong>Super Admin</strong> đã quay trở lại!</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="card-stat bg-tòa-nhà shadow-sm">
                            <h2 class="fw-bold">@data.total_buildings</h2>
                            <span class="small">Tòa nhà</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card-stat bg-phòng shadow-sm">
                            <h2 class="fw-bold">@data.total_rooms</h2>
                            <span class="small">Tổng số phòng</span>
                        </div>
                    </div>
                    <div class="col-12 mt-3">
                        <div class="card-stat bg-staff shadow-sm" style="background-color: #5D4037;">
                            <h2 class="fw-bold">@data.total_users</h2>
                            <span class="small">Người dùng hệ thống</span>
                        </div>
                    </div>
                </div>

                <div class="chart-box shadow-sm text-center">
                    <h6 class="fw-bold mb-3" style="color: #8B0000;">Tỷ lệ phòng theo Tòa nhà</h6>
                    <canvas id="apartmentChart"></canvas>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="row g-3 h-100">
                    <div class="col-md-4">
                        <div class="feature-box shadow-sm">
                            <div class="feature-icon" style="color: #D35400;"><i class="fa-solid fa-city"></i></div>
                            <h5 class="fw-bold">Tòa nhà</h5>
                            <a href="@Url.Action("Index", "Buildings")" class="btn-access mt-auto">Truy cập</a>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="feature-box shadow-sm">
                            <div class="feature-icon" style="color: #0d9488;"><i class="fa-solid fa-door-open"></i></div>
                            <h5 class="fw-bold">Căn hộ</h5>
                            <a href="@Url.Action("Index", "Apartments")" class="btn-access mt-auto" style="background-color: #0d9488;">Truy cập</a>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="feature-box shadow-sm">
                            <div class="feature-icon" style="color: #8B0000;"><i class="fa-solid fa-file-invoice-dollar"></i></div>
                            <h5 class="fw-bold">Hóa đơn</h5>
                            <a href="@Url.Action("Index", "Billing")" class="btn-access mt-auto" style="background-color: #8B0000;">Truy cập</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Lấy dữ liệu biểu đồ từ ViewBag
        const chartRawData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(data.chartData));
        
        new Chart(document.getElementById('apartmentChart'), {
            type: 'pie',
            data: {
                labels: chartRawData.map(d => 'Tòa ' + d.buildingId),
                datasets: [{
                    data: chartRawData.map(d => d.total),
                    backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF']
                }]
            }
        });
    </script>
}