@model IEnumerable<APT.Models.Building>
@{
    Layout = null; // Hoặc Layout = "_Layout" nếu Đại Ca đã có sidebar chung
    var user = ViewBag.User as APT.Models.User;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manager Dashboard - Apartment</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .sidebar-bg {
            background-color: #7d939e;
        }

        .main-bg {
            background-color: #f8f9fa;
        }

        .btn-orange {
            background-color: #d35400;
        }
    </style>
</head>
<body class="flex h-screen main-bg">

    <aside class="w-64 sidebar-bg flex flex-col items-center py-8 px-4 text-white shadow-2xl">
        <div class="w-20 h-20 rounded-full border-4 border-white overflow-hidden mb-4 bg-white">
            <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=Lucky" alt="Avatar">
        </div>
        <p class="font-bold text-sm mb-8 uppercase tracking-widest">@user?.FullName</p>

        <div class="w-full space-y-4">
            <a asp-action="Index" class="flex items-center gap-3 w-full py-3 px-6 btn-orange rounded-full font-bold shadow-lg no-underline text-white transition-all">
                <i class="fa-solid fa-house"></i> Trang chủ
            </a>

            <a asp-controller="Users" asp-action="Profile" class="flex items-center gap-3 w-full py-3 px-6 bg-white text-[#7d939e] rounded-full font-bold hover:bg-gray-100 transition-all no-underline shadow-md">
                <i class="fa-solid fa-user-gear"></i> Tài khoản
            </a>
        </div>

        <div class="mt-10 p-4 bg-black/10 rounded-2xl text-[10px] text-center opacity-80 leading-relaxed">
            <i class="fa-solid fa-circle-info mr-1"></i> Vui lòng chọn Tòa nhà từ Trang chủ để quản lý.
        </div>

        <div class="mt-auto w-full">
            <a asp-controller="Users" asp-action="Logout" class="flex items-center justify-center gap-2 w-full py-2 bg-white/20 rounded-xl hover:bg-red-500 transition-all no-underline text-white font-bold text-xs">
                <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
            </a>
        </div>
    </aside>

    <main class="flex-1 flex flex-col overflow-hidden">
        <header class="py-6 text-center border-b bg-white shadow-sm">
            <div class="flex justify-center gap-2 mb-2">
                <div class="w-2 h-2 rounded-full bg-gray-300"></div>
                <div class="w-2 h-2 rounded-full bg-gray-300"></div>
                <div class="w-2 h-2 rounded-full bg-[#d35400]"></div>
                <div class="w-2 h-2 rounded-full bg-gray-300"></div>
                <div class="w-2 h-2 rounded-full bg-gray-300"></div>
            </div>
            <h2 class="text-2xl text-gray-400 font-light italic">Xin chào, <span class="text-gray-600 font-normal">quản lý</span></h2>
        </header>

        <section class="flex-1 p-10 overflow-y-auto">
            <h3 class="text-center text-gray-700 font-bold text-xl mb-10">Các tòa nhà đang quản lý</h3>

            <div class="flex justify-center">
                @if (Model != null && Model.Any())
                {
                    @foreach (var building in Model)
                    {
                        <div class="w-80 bg-white rounded-3xl shadow-xl overflow-hidden hover:scale-105 transition-transform border border-gray-100">
                            <div class="h-44 bg-gray-200">
                                <img src="https://images.unsplash.com/photo-1449156001933-468b7bb25963?q=80&w=500&auto=format&fit=crop"
                                     class="w-full h-full object-cover" alt="Building image">
                            </div>
                            <div class="p-6">
                                <h4 class="font-bold text-[#7d939e] text-lg mb-2 uppercase">@building.Name</h4>
                                <p class="text-[10px] text-gray-500 mb-4 leading-relaxed">
                                    <i class="fa-solid fa-location-dot mr-1"></i> @building.Address
                                </p>
                                <div class="flex gap-4 text-xs font-bold text-gray-600 mb-6">
                                    <span><i class="fa-solid fa-layer-group mr-1"></i> @building.TotalFloors Tầng</span>
                                    <span><i class="fa-solid fa-warehouse mr-1"></i> @(building.Basements?.Count ?? 0) Hầm</span>
                                </div>
                                <a asp-controller="Apartments" asp-action="Index" asp-route-buildingId="@building.Id"
                                   class="block w-full py-3 bg-[#7d939e] text-white text-center rounded-xl font-bold hover:bg-[#667a85] transition-all no-underline shadow-lg text-sm">
                                    <i class="fa-solid fa-door-open mr-2"></i> Xem Danh sách Phòng
                                </a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center p-10 bg-white rounded-3xl shadow-md border-2 border-dashed">
                        <i class="fa-solid fa-building-circle-exclamation text-4xl text-gray-300 mb-4"></i>
                        <p class="text-gray-500">Bạn chưa được phân công tòa nhà nào.</p>
                    </div>
                }
            </div>
        </section>
    </main>

</body>
</html>