@model IEnumerable<APT.Models.Building>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chọn Tòa Nhà";

    // Danh sách ảnh kiến trúc chất lượng cao
    var randomImages = new string[] {
        "https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?q=80&w=1000",
        "https://images.unsplash.com/photo-1460317442991-0ec239f636a7?q=80&w=1000",
        "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1000",
        "https://images.unsplash.com/photo-1512917774080-9991f1c4c750?q=80&w=1000",
        "https://images.unsplash.com/photo-1449156001437-3a1621dfbe69?q=80&w=1000"
    };
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-[#f5ebe0] py-10 px-4 md:px-10 font-sans">
    <div class="max-w-7xl mx-auto bg-[#ddb892] rounded-[50px] p-8 md:p-12 shadow-2xl">

        @* --- HEADER --- *@
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
            <div>
                <h2 class="text-[#8b0000] text-4xl font-black flex items-center gap-4 uppercase tracking-tighter">
                    <i class="fa-solid fa-city"></i> Chọn Tòa Nhà Quản Lý
                </h2>
                <p class="text-[#4a3728] font-bold mt-2 italic opacity-90">
                    Chào mừng Đại Ca. Vui lòng chọn Block để bắt đầu.
                </p>
            </div>

            <div class="flex flex-wrap gap-4">
                <a asp-controller="Buildings" asp-action="Create" class="bg-[#27ae60] hover:bg-[#1e8449] text-white px-8 py-4 rounded-2xl font-black shadow-lg transition-all flex items-center gap-2 active:scale-95 no-underline uppercase text-xs">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> Tạo Tòa Mới
                </a>

                <a asp-controller="Dashboard" asp-action="Index" class="bg-white text-[#d35400] px-8 py-4 rounded-2xl font-black hover:bg-gray-100 shadow-md transition-all flex items-center gap-2 no-underline uppercase text-xs">
                    <i class="fa-solid fa-gauge-high"></i> Dashboard
                </a>
            </div>
        </div>

        @* --- GRID DANH SÁCH TÒA NHÀ --- *@
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            @{
                int index = 0;
            }
            @foreach (var item in Model)
            {
                var displayImg = randomImages[index % randomImages.Length];
                index++;

                <div class="bg-white rounded-[45px] overflow-hidden shadow-2xl hover:shadow-orange-400/50 transition-all duration-500 group border-4 border-transparent hover:border-[#d35400]/30 flex flex-col h-full hover:-translate-y-2">

                    @* KHỐI ẢNH *@
                    <div class="h-60 bg-gray-200 overflow-hidden relative shrink-0">
                        <img src="@displayImg"
                             class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"
                             alt="Building Image">

                        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>

                        <div class="absolute top-5 right-5 bg-white/90 backdrop-blur px-4 py-2 rounded-2xl text-[10px] font-black uppercase text-[#d35400] shadow-xl border border-orange-100">
                            ID: #@item.Id
                        </div>
                    </div>

                    @* NỘI DUNG *@
                    <div class="p-8 flex flex-col flex-grow">
                        <h3 class="text-[#d35400] text-2xl font-black mb-4 uppercase tracking-tight group-hover:text-black transition-colors line-clamp-1">
                            @item.Name
                        </h3>

                        <div class="space-y-4 mb-8 flex-grow">
                            <p class="text-[12px] text-gray-500 font-bold flex items-start gap-3 leading-relaxed min-h-[48px] line-clamp-2">
                                <i class="fa-solid fa-location-dot mt-1 text-[#b08968] text-lg"></i>
                                @(string.IsNullOrEmpty(item.Address) ? "Khu vực Hutech - TP.HCM" : item.Address)
                            </p>

                            <div class="flex gap-8 text-sm font-black text-[#4a3728] uppercase tracking-wide border-t border-dashed border-gray-100 pt-4">
                                <span class="flex items-center gap-2">
                                    <i class="fa-solid fa-layer-group text-[#d35400]"></i> @item.TotalFloors
                                </span>
                                <span class="flex items-center gap-2">
                                    @* Giả định hầm cố định là 1 nếu DB không lưu *@
                                    <i class="fa-solid fa-warehouse text-[#d35400]"></i> 1 Hầm
                                </span>
                            </div>
                        </div>

                        @* NÚT TRUY CẬP *@
                        <a asp-controller="Apartments" asp-action="Index" asp-route-building_id="@item.Id"
                           class="block w-full bg-[#d35400] text-white text-center py-4 rounded-2xl font-black no-underline">
                            Xem Danh Sách Phòng
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>