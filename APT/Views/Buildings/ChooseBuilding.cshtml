@model IEnumerable<APT.Models.Building>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Chọn Tòa Nhà";

    // Danh sách ảnh dự phòng cực đẹp cho các Block nếu DB chưa có ảnh
    var randomImages = new string[] {
        "https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?q=80&w=1000", // Landmark style
        "https://images.unsplash.com/photo-1460317442991-0ec239f636a7?q=80&w=1000", // Modern Glass
        "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1000", // Corporate
        "https://images.unsplash.com/photo-1512917774080-9991f1c4c750?q=80&w=1000", // Luxury Apartment
        "https://images.unsplash.com/photo-1449156001437-3a1621dfbe69?q=80&w=1000"  // Night City
    };
}

<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<div class="min-h-screen bg-[#f5ebe0] py-10 px-4 md:px-10 font-sans">
    <div class="max-w-7xl mx-auto bg-[#ddb892] rounded-[50px] p-8 md:p-12 shadow-2xl">

        @* --- HEADER --- *@
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
            <div>
                <h2 class="text-[#8b0000] text-3xl font-black flex items-center gap-3 uppercase tracking-tighter">
                    <i class="fa-solid fa-city"></i> Chọn Tòa Nhà Quản Lý
                </h2>
                <p class="text-[#4a3728] font-bold mt-2 italic opacity-80">
                    Hệ thống quản lý cư dân & căn hộ chuyên nghiệp.
                </p>
            </div>

            @* Nút trỏ về trang tạo batch *@
            <a asp-controller="Apartments" asp-action="CreateBatch" class="bg-[#27ae60] hover:bg-[#1e8449] text-white px-6 py-3 rounded-2xl font-bold shadow-lg transition-all flex items-center gap-2 active:scale-95 no-underline">
                <i class="fa-solid fa-wand-magic-sparkles"></i> Tạo phòng tự động
            </a>
        </div>

        @* --- GRID DANH SÁCH TÒA NHÀ --- *@
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            @{
                int index = 0;
            }
            @foreach (var item in Model)
            {
                // Lấy ảnh từ mảng dựa trên index để mỗi block một ảnh khác nhau
                var displayImg = randomImages[index % randomImages.Length];
                index++;

                <div class="bg-white rounded-[40px] overflow-hidden shadow-2xl hover:shadow-orange-300 transition-all group border-4 border-transparent hover:border-[#d35400]/20 flex flex-col h-full">

                    @* KHỐI ẢNH *@
                    <div class="h-56 bg-gray-200 overflow-hidden relative shrink-0">
                        <img src="@displayImg"
                             class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                             alt="Building Image">

                        @* Lớp phủ Gradient cho chữ nổi bật *@
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>

                        @* Badge trạng thái nhỏ *@
                        <div class="absolute top-4 right-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-[10px] font-black uppercase text-[#d35400] shadow-sm">
                            Đang hoạt động
                        </div>
                    </div>

                    @* NỘI DUNG *@
                    <div class="p-8 flex flex-col flex-grow">
                        <h3 class="text-[#d35400] text-2xl font-black mb-3 uppercase tracking-tight group-hover:text-black transition-colors">
                            @item.Name
                        </h3>

                        <div class="space-y-3 mb-8 flex-grow">
                            <p class="text-[11px] text-gray-500 font-bold flex items-start gap-2 leading-relaxed min-h-[40px]">
                                <i class="fa-solid fa-location-dot mt-1 text-[#b08968]"></i>
                                @(string.IsNullOrEmpty(item.Address) ? "Chưa cập nhật địa chỉ" : item.Address)
                            </p>

                            <div class="flex gap-6 text-sm font-black text-[#4a3728] uppercase tracking-wide">
                                <span class="flex items-center gap-1.5">
                                    <i class="fa-solid fa-layer-group text-[#d35400] text-xs"></i> @item.TotalFloors Tầng
                                </span>
                                <span class="flex items-center gap-1.5">
                                    <i class="fa-solid fa-warehouse text-[#d35400] text-xs"></i> @(item.Basements?.Count ?? 0) Hầm
                                </span>
                            </div>
                        </div>

                        @* NÚT TRUY CẬP *@
                        <a asp-controller="Apartments" asp-action="Index" asp-route-building_id="@item.Id"
                           class="block w-full bg-[#d35400] text-white text-center py-4 rounded-2xl font-black hover:bg-black transition-all no-underline shadow-xl shadow-orange-100 uppercase tracking-widest text-[11px] active:scale-95">
                            <i class="fa-solid fa-door-open mr-2"></i> Xem Danh sách Phòng
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>