@model APT.Models.Resident
@{
    Layout = null;
    var latestBill = ViewBag.LatestBill as APT.Models.Bill;
    var services = ViewBag.Services as List<APT.Models.Service>;
    var apartment = ViewBag.Apartment as APT.Models.Apartment;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Trang chủ Cư dân - @(Model?.FullName ?? "Cư dân")</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .sidebar-bg {
            background-color: #7d939e;
        }

        .btn-active {
            background-color: #d35400 !important;
            color: white !important;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }
    </style>
</head>
<body class="flex h-screen bg-[#f1f3f5] font-sans">

    @* --- THANH SIDEBAR --- *@
    <aside class="w-64 sidebar-bg flex flex-col items-center py-8 px-4 text-white shrink-0 shadow-2xl">
        <div class="w-20 h-20 rounded-full border-4 border-white overflow-hidden mb-8 bg-white flex items-center justify-center">
            <i class="fa-solid fa-user text-3xl text-gray-400"></i>
        </div>
        <div class="w-full space-y-2">
            <a href="#" class="flex items-center gap-3 w-full py-2.5 px-6 btn-active rounded-full font-bold no-underline text-sm shadow-lg">
                <i class="fa-solid fa-house"></i> Trang chủ
            </a>
            <a href="#" class="flex items-center gap-3 w-full py-2.5 px-6 bg-white text-gray-500 rounded-full font-bold no-underline text-sm hover:bg-gray-100 transition-all">
                <i class="fa-solid fa-user-circle"></i> Tài khoản
            </a>
        </div>
        <div class="mt-auto w-full">
            <a asp-controller="Users" asp-action="Logout" class="flex items-center justify-center gap-2 w-full py-2 bg-white/20 rounded-xl text-white font-bold text-xs no-underline hover:bg-red-500 transition-all">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Đăng xuất
            </a>
        </div>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto">
        @* --- HÓA ĐƠN THÁNG --- *@
        <div class="bg-white rounded-3xl shadow-xl border-t-[6px] border-purple-600 overflow-hidden mb-8">
            <div class="p-6 border-b border-gray-50 flex justify-between items-center bg-purple-50/30">
                <h2 class="text-sm font-black text-purple-700 uppercase tracking-widest flex items-center gap-2">
                    <i class="fa-solid fa-file-invoice-dollar"></i> Hóa đơn tháng mới nhất
                </h2>
                @if (latestBill != null && !latestBill.Status)
                {
                    <span class="bg-red-100 text-red-600 px-3 py-1 rounded-full text-[10px] font-black uppercase">Chưa thanh toán</span>
                }
            </div>

            <div class="p-8">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-y-6 text-xs font-bold text-gray-400">
                    @* FIX: Bao ngoặc (apartment?.RentPrice ?? 0) để ép về kiểu decimal thuần *@
                    <div><i class="fa-solid fa-house mr-1 text-purple-400"></i> Tiền phòng: <span class="text-gray-700">@((apartment?.RentPrice ?? 0).ToString("N0")) đ</span></div>
                    <div><i class="fa-solid fa-droplet mr-1 text-blue-400"></i> Tiền Nước: <span class="text-gray-700">Theo chỉ số</span></div>
                    <div><i class="fa-solid fa-hand-holding-dollar mr-1 text-green-400"></i> Phí Quản lý: <span class="text-gray-700">@((apartment?.ManagementPrice ?? 0).ToString("N0")) đ</span></div>
                </div>

                <div class="mt-8 pt-6 border-t border-dashed flex justify-between items-end">
                    <div>
                        <p class="text-[10px] font-black text-gray-300 uppercase tracking-widest">Tổng cộng thanh toán</p>
                        <p class="text-3xl font-black text-purple-600 tracking-tighter">
                            @* FIX: Bao ngoặc (latestBill?.TotalMoney ?? 0) để ép về kiểu int thuần *@
                            @((latestBill?.TotalMoney ?? 0).ToString("N0")) <span class="text-sm">đ</span>
                        </p>
                    </div>
                    <button class="bg-[#219ebc] text-white px-8 py-3 rounded-2xl font-black text-[11px] uppercase tracking-widest shadow-lg hover:bg-black active:scale-95 transition-all">
                        Thanh toán ngay
                    </button>
                </div>
            </div>
        </div>

        @* --- DANH SÁCH DỊCH VỤ --- *@
        <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
            <div class="p-6">
                <h2 class="text-sm font-black text-orange-600 uppercase tracking-widest flex items-center gap-2 mb-1">
                    <i class="fa-solid fa-concierge-bell"></i> Dịch vụ tòa nhà
                </h2>
                <p class="text-[9px] text-gray-400 font-bold ml-6 uppercase italic">Đăng ký thêm tiện ích cho căn hộ</p>
            </div>

            <table class="w-full text-left">
                <thead class="bg-gray-50 text-[10px] uppercase font-black text-gray-400 tracking-widest">
                    <tr>
                        <th class="px-6 py-4">Tên dịch vụ</th>
                        <th class="px-6 py-4 text-right">Đơn giá</th>
                        <th class="px-6 py-4 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 custom-scrollbar">
                    @if (services != null && services.Any())
                    {
                        foreach (var s in services)
                        {
                            <tr class="hover:bg-gray-50 transition-all">
                                <td class="px-6 py-5 font-bold text-gray-700 text-sm italic">@s.Name</td>
                                <td class="px-6 py-5 text-right">
                                    @* FIX: Bao ngoặc s.Price để dùng ToString *@
                                    <span class="text-green-600 font-black">@((s.Price).ToString("N0"))</span>
                                    <span class="bg-gray-100 text-gray-400 px-2 py-0.5 rounded text-[9px] font-bold ml-1 uppercase">@s.Unit</span>
                                </td>
                                <td class="px-6 py-5 text-center">
                                    <button class="bg-gray-800 text-white px-4 py-1.5 rounded-full text-[9px] font-black uppercase hover:bg-black transition-all">
                                        Đăng ký
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>