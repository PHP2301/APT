@model APT.Models.Resident
@{
    Layout = null;
    var apartment = ViewBag.Apartment as APT.Models.Apartment;
    // FIX: Đảm bảo buildingId không null để các nút quay lại không bị lỗi link
    int buildingId = ViewBag.BuildingId ?? 0;
    var freeResidents = ViewBag.FreeResidents as List<APT.Models.Resident>;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Thiết lập Chủ hộ - @(apartment?.FullRoomName ?? "...")</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .sidebar-bg {
            background-color: #7d939e;
        }

        .tab-btn.active {
            background-color: #4a5568;
            color: white;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
        }

        .tab-content.hidden {
            display: none;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }
    </style>
</head>
<body class="flex h-screen bg-[#f1f3f5] font-sans">

    <aside class="w-64 sidebar-bg flex flex-col items-center py-8 px-4 text-white shrink-0 shadow-2xl">
        <div class="w-20 h-20 rounded-full border-4 border-white overflow-hidden mb-4 bg-white">
            <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=Lucky" alt="Avatar">
        </div>
        <p class="font-bold text-sm mb-8 uppercase tracking-widest text-center">Manager</p>
        <div class="w-full space-y-2">
            <a asp-controller="Dashboard" asp-action="Index" class="flex items-center gap-3 w-full py-2.5 px-6 bg-white text-gray-500 rounded-full font-bold no-underline text-sm shadow-sm hover:bg-gray-100 transition-all">
                <i class="fa-solid fa-house"></i> Trang chủ
            </a>
            <p class="text-[10px] uppercase font-black tracking-widest mt-6 mb-2 opacity-60 px-4 italic">Quản lý tòa nhà</p>
            @* FIX: Sử dụng đúng building_id khớp với Controller *@
            <a asp-controller="Apartments" asp-action="Index" asp-route-building_id="@buildingId" class="flex items-center gap-3 w-full py-2.5 px-6 bg-[#d35400] text-white rounded-full font-bold no-underline text-sm shadow-lg hover:scale-105 transition-all">
                <i class="fa-solid fa-door-open"></i> Danh sách Phòng
            </a>
        </div>
    </aside>

    <main class="flex-1 p-10 overflow-y-auto">
        <div class="max-w-5xl mx-auto">
            <div class="mb-6">
                <a asp-controller="Apartments" asp-action="Index" asp-route-building_id="@buildingId" class="text-[10px] text-gray-400 font-black hover:underline no-underline uppercase tracking-widest italic transition-all">
                    ← Quay lại sơ đồ phòng
                </a>
            </div>

            <div class="bg-white rounded-[25px] p-8 shadow-sm border-l-[8px] border-green-500 mb-8 flex justify-between items-center">
                <div>
                    <h2 class="text-3xl font-black text-green-600 tracking-tighter uppercase">Thiết lập Chủ hộ mới</h2>
                    <p class="text-[11px] text-gray-400 font-bold mt-1 uppercase italic">Căn hộ: <span class="text-gray-700">@apartment?.FullRoomName</span></p>
                </div>
                <div class="text-right">
                    <p class="text-[10px] text-gray-400 font-black uppercase mb-1">Giá thuê hiện tại</p>
                    @* FIX: Ép kiểu decimal? để ToString hoạt động *@
                    <p class="text-2xl font-black text-gray-800 tracking-tighter">@((apartment?.RentPrice ?? 0).ToString("N0")) <span class="text-sm font-bold text-gray-300">đ</span></p>
                </div>
            </div>

            <div class="flex gap-2 mb-8">
                <button onclick="switchTab('create')" id="btn-create" class="tab-btn active px-8 py-3 rounded-xl text-[11px] font-black uppercase tracking-widest flex items-center gap-2 transition-all">
                    <i class="fa-solid fa-user-plus"></i> Tạo mới thủ công
                </button>
                <button onclick="switchTab('existing')" id="btn-existing" class="tab-btn bg-white text-gray-400 border border-gray-100 px-8 py-3 rounded-xl text-[11px] font-black uppercase tracking-widest flex items-center gap-2 hover:bg-gray-50 transition-all">
                    <i class="fa-solid fa-list-ul"></i> Chọn từ danh sách chờ
                </button>
            </div>

            @* TAB 1: TẠO MỚI *@
            <div id="tab-create" class="tab-content bg-white rounded-[40px] shadow-2xl p-10 border border-gray-50">
                <h4 class="text-sm font-black text-gray-700 mb-10 border-b pb-6 border-dashed border-gray-100 uppercase tracking-widest">Thông tin Chủ hộ mới</h4>
                <form asp-action="ProcessAddToApartment" method="post" class="space-y-8">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="apartmentId" value="@(apartment?.Id ?? 0)" />
                    <input type="hidden" name="building_id" value="@buildingId" />

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-8">
                        <div>
                            <label class="block text-[11px] font-black text-gray-400 uppercase mb-2 ml-1">Họ và tên *</label>
                            <input type="text" name="FullName" placeholder="Ví dụ: Nguyễn Văn A" class="w-full px-5 py-4 rounded-2xl bg-gray-50 border border-transparent outline-none focus:ring-4 focus:ring-green-100 focus:bg-white focus:border-green-400 transition-all text-sm font-bold" required />
                        </div>
                        <div>
                            <label class="block text-[11px] font-black text-gray-400 uppercase mb-2 ml-1">Số điện thoại *</label>
                            <input type="text" name="phone" placeholder="09xxxxxxxx" class="w-full px-5 py-4 rounded-2xl bg-gray-50 border border-transparent outline-none focus:ring-4 focus:ring-green-100 focus:bg-white focus:border-green-400 transition-all text-sm font-bold" required />
                        </div>
                        <div>
                            <label class="block text-[11px] font-black text-gray-400 uppercase mb-2 ml-1">CCCD / CMND *</label>
                            <input type="text" name="id_card" placeholder="Số định danh..." class="w-full px-5 py-4 rounded-2xl bg-gray-50 border border-transparent outline-none focus:ring-4 focus:ring-green-100 focus:bg-white focus:border-green-400 transition-all text-sm font-bold" required />
                        </div>
                        <div>
                            <label class="block text-[11px] font-black text-gray-400 uppercase mb-2 ml-1">Email *</label>
                            <input type="email" name="email" placeholder="abc@gmail.com" class="w-full px-5 py-4 rounded-2xl bg-gray-50 border border-transparent outline-none focus:ring-4 focus:ring-green-100 focus:bg-white focus:border-green-400 transition-all text-sm font-bold" required />
                        </div>
                    </div>

                    <div class="flex justify-end pt-10 border-t border-gray-50">
                        <button type="submit" class="bg-[#4a5568] text-white px-12 py-4 rounded-2xl font-black text-[11px] uppercase tracking-widest flex items-center gap-3 shadow-xl hover:bg-black active:scale-95 transition-all">
                            <i class="fa-solid fa-circle-check"></i> Xác nhận & Thêm vào phòng
                        </button>
                    </div>
                </form>
            </div>

            @* TAB 2: CHỌN CÓ SẴN *@
            <div id="tab-existing" class="tab-content hidden bg-white rounded-[40px] shadow-2xl p-10 border border-gray-50">
                <div class="relative mb-8">
                    <input type="text" id="searchInput" placeholder="Tìm tên hoặc SĐT..." class="w-full pl-12 pr-6 py-4 rounded-2xl bg-gray-50 border-none outline-none focus:ring-2 focus:ring-orange-200 text-sm font-bold" />
                    <i class="fa-solid fa-search absolute left-5 top-5 text-gray-300"></i>
                </div>

                <div class="max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
                    <table class="w-full text-left">
                        <thead class="sticky top-0 bg-white text-[10px] uppercase font-black text-gray-400 tracking-widest border-b">
                            <tr>
                                <th class="pb-4 px-4">Cư dân</th>
                                <th class="pb-4">SĐT</th>
                                <th class="pb-4 text-right">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50" id="residentTable">
                            @if (freeResidents != null && freeResidents.Any())
                            {
                                foreach (var r in freeResidents)
                                {
                                    <tr class="hover:bg-gray-50 transition-all group">
                                        <td class="py-5 px-4">
                                            <div class="font-black text-gray-700 text-sm">@r.FullName</div>
                                            <div class="text-[10px] text-gray-400">CCCD: @r.id_card</div>
                                        </td>
                                        <td class="py-5 text-sm font-bold text-gray-500">@r.phone</td>
                                        <td class="py-5 text-right">
                                            <form asp-action="AssignExistingResident" method="post" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="residentId" value="@r.Id" />
                                                <input type="hidden" name="apartmentId" value="@(apartment?.Id ?? 0)" />
                                                <button type="submit" class="bg-green-500 text-white w-10 h-10 rounded-xl shadow-lg hover:bg-black transition-all active:scale-90">
                                                    <i class="fa-solid fa-plus text-xs"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="3" class="py-20 text-center text-gray-300 font-bold italic text-sm">Không có cư dân nào trong danh sách chờ</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <script>
        function switchTab(tab) {
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active', 'bg-white', 'text-gray-400', 'border');
                btn.classList.add('bg-white', 'text-gray-400', 'border');
            });
            const activeBtn = document.getElementById('btn-' + tab);
            activeBtn.classList.add('active');
            activeBtn.classList.remove('bg-white', 'text-gray-400', 'border');

            document.querySelectorAll('.tab-content').forEach(content => content.classList.add('hidden'));
            document.getElementById('tab-' + tab).classList.remove('hidden');
        }

        document.getElementById('searchInput')?.addEventListener('keyup', function() {
            let value = this.value.toLowerCase();
            let rows = document.querySelectorAll('#residentTable tr');
            rows.forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(value) ? '' : 'none';
            });
        });
    </script>
</body>
</html>