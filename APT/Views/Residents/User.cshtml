@model APT.Models.User
@{
    Layout = null;
    var latestBill = ViewBag.LatestBill as APT.Models.Bill;
    var services = ViewBag.Services as List<APT.Models.Service>;
    var apartment = ViewBag.Apartment as APT.Models.Apartment;

    // 1. Phí cố định
    decimal roomPrice = apartment?.RentPrice ?? 0;
    decimal managementPrice = apartment?.ManagementPrice ?? 0;
    decimal basePrice = roomPrice + managementPrice;

    // 2. Logic Tổng tiền
    decimal finalAmount = latestBill != null ? latestBill.TotalMoney : basePrice;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Trang chủ Cư dân - @(Model?.FullName ?? "Cư dân")</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        .sidebar-bg {
            background-color: #7d939e;
        }

        .btn-active {
            background-color: #d35400 !important;
            color: white !important;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        .modal-open {
            overflow: hidden;
        }
    </style>
</head>
<body class="flex h-screen bg-[#f1f3f5] font-sans">

    @* --- SIDEBAR --- *@
    <aside class="w-64 sidebar-bg flex flex-col items-center py-8 px-4 text-white shrink-0 shadow-2xl">
        <div class="w-20 h-20 rounded-full border-4 border-white overflow-hidden mb-8 bg-white flex items-center justify-center shadow-lg">
            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=@Model.FullName" alt="Avatar">
        </div>
        <p class="font-black text-sm mb-8 uppercase tracking-[3px]">Cư Dân</p>
        <div class="w-full space-y-2">
            <a asp-controller="Users" asp-action="Profile" class="flex items-center gap-3 w-full py-2.5 px-6 btn-active rounded-full font-bold no-underline text-sm shadow-lg hover:scale-105 transition-all">
                <i class="fa-solid fa-user-circle"></i> Cá nhân
            </a>
        </div>
        <div class="mt-auto w-full">
            <a asp-controller="Users" asp-action="Logout" class="flex items-center justify-center gap-2 w-full py-2 bg-white/20 rounded-xl text-white font-bold text-xs no-underline hover:bg-red-500 transition-all">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Đăng xuất
            </a>
        </div>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto custom-scrollbar">
        @* --- HÓA ĐƠN --- *@
        <div class="bg-white rounded-[32px] shadow-xl border-t-[8px] border-purple-600 overflow-hidden mb-8">
            <div class="p-6 border-b border-gray-50 flex justify-between items-center bg-purple-50/30">
                <h2 class="text-xs font-black text-purple-700 uppercase tracking-widest flex items-center gap-2">
                    <i class="fa-solid fa-file-invoice-dollar text-lg"></i> Hóa đơn tháng mới nhất
                </h2>
                @if (latestBill != null && latestBill.Status == true)
                {
                    <span class="bg-green-100 text-green-600 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-tighter">Đã thanh toán</span>
                }
                else
                {
                    <span class="bg-red-100 text-red-600 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-tighter shadow-sm">Chưa thanh toán</span>
                }
            </div>

            <div class="p-10">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
                    <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 font-bold">
                        <p class="text-[9px] text-gray-400 uppercase mb-2 tracking-widest">Tiền phòng</p>
                        <p class="text-xl">@roomPrice.ToString("N0") đ</p>
                    </div>
                    <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 font-bold">
                        <p class="text-[9px] text-gray-400 uppercase mb-2 tracking-widest">Phí quản lý</p>
                        <p class="text-xl text-green-600">@managementPrice.ToString("N0") đ</p>
                    </div>
                    <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100 font-bold">
                        <p class="text-[9px] text-gray-400 uppercase mb-2 tracking-widest">Tiền nước</p>
                        <p class="text-xl text-blue-500">
                            @{
                                decimal waterMoney = (latestBill != null && latestBill.TotalMoney > basePrice) ? (latestBill.TotalMoney - basePrice) : 0;
                            }
                            @(waterMoney > 0 ? waterMoney.ToString("N0") : "Chờ chốt") đ
                        </p>
                    </div>
                </div>

                <div class="pt-8 border-t border-dashed flex justify-between items-center">
                    <div>
                        <p class="text-[10px] font-black text-gray-300 uppercase tracking-[4px] mb-1">TỔNG HÓA ĐƠN</p>
                        <p class="text-5xl font-black text-purple-600">@finalAmount.ToString("N0") <span class="text-xl font-normal">đ</span></p>
                    </div>

                    @if (latestBill != null && latestBill.Status == true)
                    {
                        <button disabled class="bg-gray-100 text-gray-400 px-10 py-5 rounded-[24px] font-black text-xs uppercase cursor-not-allowed">
                            <i class="fa-solid fa-check-circle mr-2"></i> ĐÃ HOÀN TẤT
                        </button>
                    }
                    else
                    {
                        @Html.AntiForgeryToken()
                        <button onclick="openPaymentModal(@(apartment?.Id ?? 0), @finalAmount)"
                                class="bg-purple-600 text-white px-10 py-5 rounded-[24px] font-black text-xs uppercase shadow-xl hover:bg-black hover:scale-105 transition-all">
                            <i class="fa-solid fa-credit-card mr-2"></i> THANH TOÁN NGAY
                        </button>
                    }
                </div>
            </div>
        </div>
    </main>

    @* --- MODAL QR THANH TOÁN --- *@
    <div id="qrModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-[40px] w-full max-w-md overflow-hidden shadow-2xl border-t-[10px] border-green-500">
            <div class="p-8 text-center">
                <div class="w-16 h-16 bg-green-100 text-green-600 rounded-3xl flex items-center justify-center mx-auto mb-4">
                    <i class="fa-solid fa-qrcode text-2xl"></i>
                </div>
                <h3 class="text-2xl font-black text-gray-800 uppercase">Quét QR chuyển khoản</h3>
                <p class="text-[10px] text-gray-400 font-bold mt-1">NGUYEN HAI LONG - 02600202005 - VPBANK</p>

                <div class="my-6 p-4 bg-gray-50 rounded-[32px] border-2 border-dashed border-gray-200">
                    <img id="imgQR" src="" alt="VietQR" class="w-full h-auto rounded-2xl shadow-sm">
                </div>

                <div class="space-y-3">
                    <button id="btnConfirmPaid" onclick="confirmPaidStep()" class="w-full py-4 bg-green-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-black transition-all">
                        <i class="fa-solid fa-check-circle mr-2"></i> TÔI ĐÃ THANH TOÁN
                    </button>
                    <button onclick="closeQRModal()" class="w-full py-3 text-gray-400 font-bold text-xs uppercase hover:text-red-500 transition-colors">
                        ĐÓNG
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let currentAptId = 0;
        let currentAmount = 0;

        function openPaymentModal(aptId, amount) {
            currentAptId = aptId;
            currentAmount = amount;

            // Tạo link QR VietQR
            const bankId = "VPB";
            const accountNo = "02600202005";
            const description = `Thanh toan tien phong P${aptId}`;
            const qrUrl = `https://img.vietqr.io/image/${bankId}-${accountNo}-compact.png?amount=${amount}&addInfo=${encodeURIComponent(description)}&accountName=NGUYEN%20HAI%20LONG`;

            document.getElementById('imgQR').src = qrUrl;
            document.getElementById('qrModal').classList.remove('hidden');
            document.body.classList.add('modal-open');
        }

        function closeQRModal() {
            document.getElementById('qrModal').classList.add('hidden');
            document.body.classList.remove('modal-open');
        }

        function confirmPaidStep() {
            const btn = document.getElementById('btnConfirmPaid');
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            // Hiệu ứng chờ 5 giây
            btn.disabled = true;
            btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin mr-2"></i> ĐANG KIỂM TRA (5S)...`;

            setTimeout(() => {
                // Gọi API thực tế để cập nhật Database
                fetch(`/Billing/ResidentProcessPayment?apartmentId=${currentAptId}&amount=${currentAmount}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                })
                .then(res => res.json())
                .then(data => {
                    closeQRModal();
                    if (data.success) {
                        Swal.fire({
                            title: 'Thành công!',
                            text: 'Đại Ca đã thanh toán hóa đơn thành công rực rỡ!',
                            icon: 'success',
                            confirmButtonColor: '#28a745'
                        }).then(() => location.reload());
                    } else {
                        Swal.fire('Lỗi', data.message, 'error');
                        btn.disabled = false;
                        btn.innerHTML = `<i class="fa-solid fa-check-circle mr-2"></i> TÔI ĐÃ THANH TOÁN`;
                    }
                })                                                                 
                .catch(() => {
                    Swal.fire('Lỗi', 'Không thể kết nối máy chủ!', 'error');
                    btn.disabled = false;
                });
            }, 5000);
        }
    </script>
</body>
</html>